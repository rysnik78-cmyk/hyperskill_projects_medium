def mkdir(path):
    try:
        os.mkdir(path)
    except FileExistsError:
        print("The directory already exists")

def absolute_path_of_file(path):
    if ':' in path:
        return path
    else:
        return os.getcwd() + os.sep + path


def absolute_path_of_dir(dir):
    current_dir = os.getcwd()
    if dir == '..':
        current_dir_split = current_dir.split(os.sep)
        return os.sep.join(current_dir_split[:-1])
    if dir == '.':
        return current_dir
    if ':' in dir:
        return dir
    else:
        return current_dir + os.sep + dir


