def pwd():  # tells you in which directory you currently are
    return os.getcwd()


def cd(path):  # changes the current directory
    try:
        os.chdir(path)
    except FileNotFoundError:
        print("Directory does not exist")
    absolute_dir = os.getcwd()
    current_dir = absolute_dir.split("\\")[-1]
    print(current_dir)


def ls(param=None):
    raw_list_of_files = os.listdir()
    if raw_list_of_files:
        alfa = sorted(raw_list_of_files)
        list_of_files_sorted = sorted(alfa, key=lambda x: len(x.split('.')))  # directories first then files
        for file in list_of_files_sorted:
            # print(file)
            if param is None or '.' not in file:
                print(file)
            elif '.' in file and param == "-l":
                print(file + ' ' + str(os.stat(file).st_size))
            elif '.' in file and param == "-lh":
                print(file + ' ' + hr_size_string(os.stat(file).st_size))


def hr_size_string(file_size_bytes):
    names = ['B', 'KB', 'MB', 'GB']
    for n, name in enumerate(names):
        if file_size_bytes < 1024 ** (n + 1) or name == 'GB':
            return f'{round(file_size_bytes / (1024 ** n))}{name}'
    return None

def rm(path):

    if path is None:
        print("Specify the file or directory")

    elif is_file(path):
        # print('file')
        try:
            os.remove(path)
        except FileNotFoundError:
            print("No such file or directory")

    elif is_dir(path):  # windows access denied
        print('directory rm')
        try:
            shutil.rmtree(path)
        except FileNotFoundError:
            print("No such file or directory")

    elif is_template(path):
        extension = is_template(path)
        file_not_found = True
        for file in os.listdir(os.getcwd()):
            if file.endswith(extension):
                os.remove(file)
                file_not_found = False
        if file_not_found:
            print(f'File extension {extension} not found in this directory')


def is_file(path):
    path_split = path.split('.')
    if len(path_split) == 2:
        return path_split[0] and path_split[1]
    else:
        return False

def is_dir(path):
    return '..' in path or not '.' in path

def is_template(path):
    path_split = path.split('.')
    if len(path_split) == 2:
        if not path_split[0] and path_split[1]:
            return '.' + path_split[1]
        else:
            return None
    else:
        return None

