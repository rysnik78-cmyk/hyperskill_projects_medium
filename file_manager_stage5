def cp(old_name, new_dir):

    absolute_new_dir_path = absolute_path_of_dir(new_dir)
    print(absolute_new_dir_path)
    if not file_dir_exists(absolute_new_dir_path):
        return 'No such file or directory'

    if not is_template(old_name):  # copy not using template
        absolute_old_file_path = absolute_path_of_file(old_name)
        if not file_dir_exists(absolute_old_file_path):
            return 'No such file or directory'
        # print(absolute_old_file_path)



        old_name_split = old_name.split('\\')
        if file_dir_exists(absolute_new_dir_path + os.sep + old_name_split[-1]):
            return f'{old_name_split[-1]} already exists in this directory'
        else:
            shutil.copy(absolute_old_file_path, absolute_new_dir_path)
            return 'copied'

    else:  # copy using template
        extension = is_template(old_name)
        return_str = f'File extension {extension} not found in this directory'
        for file in os.listdir(os.getcwd()):
            if file.endswith(extension):
                if file_dir_exists(absolute_new_dir_path + os.sep + file):
                    while True:
                        print(f'{file} already exists in this directory. Replace? (y/n)')
                        answer = input()
                        if answer == 'y' or answer == 'n':
                            break
                    if answer == 'y':
                        shutil.copy(file, absolute_new_dir_path)
                        return_str = 'copied'
                        continue
                    elif answer == 'n':
                        return_str = 'copied'
                        continue
                else:
                    shutil.copy(file, absolute_new_dir_path)
                    return_str = 'copied'
                    continue
        return return_str


