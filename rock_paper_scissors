import random

class Fair_Random_Game:
    def __init__(self, list_of_options):
        self.list_of_options = list_of_options
        self.random_computer_choice = random.randint(0,len(list_of_options)-1)
        # print(f'comp choice {self.random_computer_choice}')
        self.winning_option = self.winning_option(self.random_computer_choice)
        # print(f'winning choice {self.winning_option}')
        self.draw_option = self.random_computer_choice
        # print(f'draw choice {self.draw_option}')
        self.lose_option = self.loosing_option(self.random_computer_choice)
        # print(f'lose_choice {self.lose_option}')

    def winning_option(self, opponent_choice):
        winning_options = []
        for i in range(1, len(self.list_of_options)//2 + 1):
            winning_options.append((opponent_choice + i) % len(self.list_of_options))
        return winning_options

    def loosing_option(self, opponent_choice):
        loosing_options = []
        for i in range(1, len(self.list_of_options) // 2 + 1):
            loosing_options.append((opponent_choice - i) % len(self.list_of_options))
        return loosing_options

    def result(self, user_choice):
        if user_choice in self.winning_option:
            return [f'Well done. The computer chose {self.list_of_options[self.random_computer_choice]} and failed', 100]
        elif user_choice in self.lose_option:
            return [f'Sorry, but the computer chose {self.list_of_options[self.random_computer_choice]}', 0]
        else:
            return [f'There is a draw ({self.list_of_options[self.random_computer_choice]})', 50]


