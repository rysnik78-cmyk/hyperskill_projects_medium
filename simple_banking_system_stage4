def proper_checksum(zero_checksum_number):
    zero_checksum_number_string = str(zero_checksum_number)
    sum_of_digits = 0
    for index in range(1, len(zero_checksum_number_string)):
        number = int(zero_checksum_number_string[index - 1])
        if index % 2 == 1:
            number *= 2
        if number > 9:
            number -= 9
        sum_of_digits += number
    return (10 - sum_of_digits % 10) % 10

