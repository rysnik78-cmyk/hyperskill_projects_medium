def balance(card_number):
    cur.execute(f'SELECT balance FROM card WHERE number = {card_number};')
    row_tuple = cur.fetchone()
    # print(row_tuple[0])
    return row_tuple[0]

def cust_data_verified(card_number, pin):
    cur.execute(f'SELECT pin FROM card WHERE number = {card_number};')
    row_tuple = cur.fetchone()
    # print(row_tuple)
    if row_tuple:
        if row_tuple[0] == pin:
            return True
        else:
            return False
    else:
        return False

def add_income(card_number, income):
    cur.execute(f'UPDATE card SET balance = balance + {income} WHERE number = {card_number};')
    conn.commit()

def clear_database():
    cur.execute('DELETE FROM card;')
    conn.commit()

def delete_account(card_number):
    cur.execute(f'DELETE FROM card WHERE number = {card_number};')
    conn.commit()

def account_exists(card_number):
    cur.execute(f'SELECT * FROM card WHERE number = {card_number};')
    return cur.fetchone() != None

