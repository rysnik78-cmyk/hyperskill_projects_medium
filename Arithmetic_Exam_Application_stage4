def verified_level_input():
    while True:
        input_string = input()
        if input_string == '1' or input_string == '2':
            return int(input_string)
        print('Incorrect format.')

def verified_digit_input():
    while True:
        input_string = input()
        if input_string != '':
            if (input_string[0] == "-" and input_string[1:].isdigit()) or input_string.isdigit():
                return int(input_string)
        print('Wrong format! Try again.')

def verified_yes_no_input():
    input_string = input()
    return input_string.lower()

def task(level):
    # difficulty_level = 1
    if level == 2:
        base = random.randint(11, 29)
        print(base)
        return base ** 2
    elif level == 1:
        operation = random.choice(["+", "-", "*"])
        left_side = random.randint(2, 9)
        right_side = random.randint(2, 9)
        print(f'{left_side} {operation} {right_side}')
        if operation == "+":
            return left_side + right_side
        elif operation == "-":
            return left_side - right_side
        elif operation == "*":
            return left_side * right_side


