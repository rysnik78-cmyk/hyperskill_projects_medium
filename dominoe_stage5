import random
import operator

def highest_double(pieces):
    highest_double_piece = []
    for piece in pieces:
        if not highest_double_piece:
            if piece[0] == piece[1]:
                highest_double_piece = piece
        else:
            if piece[0] == piece[1] and piece[0] > highest_double_piece[0]:
                highest_double_piece = piece

    return highest_double_piece

